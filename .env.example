# Salin file ini menjadi ".env" dan isi nilainya
# JANGAN commit file .env ke GitHub!

# Flask secret key — generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ganti_dengan_random_string_panjang_dan_unik

# Xendit API Key — dari dashboard.xendit.co
XENDIT_SECRET_KEY=xnd_development_xxxxxxxxxx

# Token webhook Xendit
XENDIT_WEBHOOK_TOKEN=token_dari_xendit_dashboard

# Email admin
ADMIN_EMAIL=admin@emailkamu.com

# URL base aplikasi (tanpa trailing slash)
BASE_URL=http://127.0.0.1:5000

# Database URL
# SQLite (default): sqlite:///sosmed_rekber.db
# PostgreSQL contoh: postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=

# Redis URL (untuk rate limit & Socket.IO queue)
# contoh: redis://127.0.0.1:6379/0
REDIS_URL=

# Mode debug
DEBUG=False

FORCE_HTTPS=True

CORS_ALLOWED_ORIGINS=

OTP_CONSOLE=False
